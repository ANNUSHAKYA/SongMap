# 1. Gemini API Key — https://ai.google.dev → Get API Key
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MOCK=false

# 2. Supabase — https://supabase.com → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your_project_ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_public_key_here
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# 3. YouTube Data API v3 (optional but recommended)
# https://console.cloud.google.com → APIs → YouTube Data API v3 → Credentials
YOUTUBE_API_KEY=your_youtube_api_key_here

# 4. Spotify API Client Credentials — https://developer.spotify.com → Dashboard
SPOTIFY_CLIENT_ID=your_spotify_client_id_here
SPOTIFY_CLIENT_SECRET=your_spotify_client_secret_here
